# ESPN Fantasy API credentials
# Get espn_s2 and SWID from browser DevTools > Application > Cookies on fantasy.espn.com
ESPN_S2=your_espn_s2_cookie_here
SWID={YOUR-SWID-WITH-BRACES-HERE}

# Django
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL)
DATABASE_URL=postgres://fantasy:fantasy@localhost:5432/fantasy_db

# Redis (Celery broker + cache)
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_TASK_ALWAYS_EAGER=False

# Optional: limit ESPN API request rate (ms between requests)
ESPN_REQUEST_DELAY_MS=300
